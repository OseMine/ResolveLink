# ResolveLink Configuration
# Copy this file to .env and adjust paths for your system

# Server
PORT=3030
HOST=127.0.0.1

# Paths
EXPORT_DIR=./exports
TEMP_DIR=./temp

# AE Installation (auto-detected if empty)
# Windows example: C:\Program Files\Adobe\Adobe After Effects 2026\Support Files
# macOS example: /Applications/Adobe After Effects 2024/
AE_PATH_WIN=
AE_PATH_MAC=

# Python (auto-detected if empty)
# Should be Python 3.10+ with Resolve scripting support
PYTHON_PATH=

# Resolve Scripting Modules (auto-detected if empty)
# Windows: C:\ProgramData\Blackmagic Design\DaVinci Resolve\Support\Developer\Scripting\Modules
# macOS: /Library/Application Support/Blackmagic Design/DaVinci Resolve/Developer/Scripting/Modules
RESOLVE_SCRIPTING_PATH=

# Watcher
WATCHER_ENABLED=true
# Extra folders to watch for rendered files (comma-separated)
# WATCH_FOLDERS=C:\Renders,D:\VFX\Output

# Logging
# LOG_LEVEL=info  (debug, info, warn, error)
