{
  "name": "resolve-link",
  "version": "1.0.0",
  "description": "Dynamic Link equivalent for DaVinci Resolve to After Effects",
  "author": "ResolveLink",
  "license": "MIT",
  "main": "electron.js",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/ui"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run ui\"",
    "ui": "cd packages/ui && npm run dev",
    "server": "node packages/server/src/index.js",
    "build": "cd packages/ui && npm run build",
    "start": "electron .",
    "install:all": "npm install && cd packages/ui && npm install",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "vitest": "^4.1.10"
  }
}
