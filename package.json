{
  "name": "resolve-link",
  "version": "1.0.0",
  "description": "Dynamic Link equivalent for DaVinci Resolve to After Effects",
  "author": "ResolveLink",
  "license": "MIT",
  "main": "electron.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run ui\"",
    "ui": "cd src && npm run dev",
    "server": "node server/index.js",
    "build": "cd src && npm run build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bridge": "node test-bridge.js"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "vitest": "^4.1.10"
  }
}
